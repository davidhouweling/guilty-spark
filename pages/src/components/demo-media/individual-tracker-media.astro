---
import styles from "./demo-media.module.css";
---

<div class={styles.grid}>
  <div class={styles.gridItem}>
    <img
      src="/images/content-refresh/home-individual-tracker-request.svg"
      width="1280"
      height="720"
      alt="Placeholder describing the requested Individual Tracker dashboard screenshot"
      loading="lazy"
      decoding="async"
      fetchpriority="low"
    />
    <div class={styles.gridCaption}>
      Requested media: Individual Tracker manager dashboard with active tracker controls and overlay action.
    </div>
  </div>
</div>
