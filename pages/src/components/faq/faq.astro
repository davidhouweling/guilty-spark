---
// FAQ component template
import SectionHeader from "../section-header/section-header.astro";
import Container from "../container/container.astro";
import styles from "./faq.module.css";

interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
  showHeader?: boolean;
}

const { items, showHeader = true } = Astro.props;
---

<section id="faq" class={styles.faqSection}>
  <Container>
    {showHeader && <SectionHeader title="Frequently Asked Queries" subtitle="Knowledge Base Protocol" />}

    <div class={styles.faqContainer}>
      {
        items.map((item) => (
          <div class={styles.faqItem}>
            <h3 class={styles.faqQuestion}>{item.question}</h3>
            <div class={styles.faqAnswer} set:html={item.answer} />
          </div>
        ))
      }
    </div>
  </Container>
</section>
