---
import styles from "./error-state.module.css";

interface Props {
  readonly title?: string;
  readonly message?: string;
}

const { title, message } = Astro.props;
---

<div class={styles.container}>
  <div class={styles.iconContainer}>
    <svg
      class={styles.errorIcon}
      viewBox="0 0 24 24"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
      focusable="false"
    >
      <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"></circle>
      <path d="M12 8V12" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
      <circle cx="12" cy="16" r="1" fill="currentColor"></circle>
    </svg>
    <div class={styles.iconGlow}></div>
  </div>
  <div class={styles.content}>
    <h3 class={styles.errorTitle}>{title ?? "Connection Failed"}</h3>
    <p class={styles.errorMessage}>{message ?? "Unable to establish connection to the server."}</p>
  </div>
</div>
