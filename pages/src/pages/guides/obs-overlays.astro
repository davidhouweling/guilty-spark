---
import { Image } from "astro:assets";
import TrackerStep1Screenshot from "../../assets/faq/tracker-step-1-live-tracker.png";
import TrackerStep2Screenshot from "../../assets/faq/tracker-step-2-settings-dialog.png";
import TrackerStep3Screenshot from "../../assets/faq/tracker-step-3-streamer-and-copy-url.png";
import ObsStep1Screenshot from "../../assets/faq/obs-step-1-browser-source-settings.png";
import IndividualTrackerStep1Screenshot from "../../assets/faq/individual-tracker-step-1-start.png";
import IndividualTrackerStep2Screenshot from "../../assets/faq/individual-tracker-step-2-streamer-settings.png";
import Layout from "../../layouts/layout.astro";
import Container from "../../components/container/container.astro";
import Heading from "../../components/heading/heading.astro";
import styles from "../_styles/content-page.module.css";
---

<Layout
  title="OBS Overlay Guide - Guilty Spark"
  description="Step-by-step setup guide for Guilty Spark overlays in OBS for both live tracker and Individual Tracker workflows."
>
  <section class={styles.contentPage}>
    <Container>
      <header class={styles.heroBlock}>
        <p class={styles.eyebrow}>Field Guide</p>
        <Heading tagName="h1" class={styles.title}>OBS Overlay Setup</Heading>
        <p class={styles.subtitle}>
          Use this guide to bring Guilty Spark overlays into OBS from either live series tracker mode or individual
          tracker mode.
        </p>
      </header>

      <section class={styles.section} aria-label="Live tracker to OBS flow">
        <div class={styles.card}>
          <h3>Flow A: Live Tracker to OBS</h3>
          <ol class={styles.steps}>
            <li>Open a live tracker session and verify the series context is active.</li>
            <li>Open overlay settings and switch to Streamer Overlay mode.</li>
            <li>Copy the generated URL.</li>
            <li>In OBS, add a Browser Source and paste the URL.</li>
            <li>Set dimensions to 1920x1080, then resize in-scene as needed.</li>
          </ol>
          <figure class={styles.mediaItem}>
            <Image src={TrackerStep1Screenshot} alt="Live tracker page with active series overview" />
            <figcaption>Live tracker view showing active series context before opening overlay settings.</figcaption>
          </figure>
          <figure class={styles.mediaItem}>
            <Image src={TrackerStep2Screenshot} alt="Configure the overlay for streamer mode" />
            <figcaption>
              Clicking settings in the top right allows you to configure the overlay for streamer mode.
            </figcaption>
          </figure>
          <figure class={styles.mediaItem}>
            <Image src={TrackerStep3Screenshot} alt="Overlay settings showing Copy URL for OBS in streamer mode" />
            <figcaption>Copy the generated OBS URL from streamer overlay mode.</figcaption>
          </figure>
          <figure class={styles.mediaItem}>
            <Image src={ObsStep1Screenshot} alt="OBS Browser Source settings for Guilty Spark overlay" />
            <figcaption>In OBS Studio add a Browser Source for live tracker overlays.</figcaption>
          </figure>
        </div>
      </section>

      <section class={styles.section} aria-label="Individual tracker to OBS flow">
        <div class={styles.card}>
          <h3>Flow B: Individual Tracker to OBS</h3>
          <ol class={styles.steps}>
            <li>Open Individual Tracker manager and select the tracker to broadcast.</li>
            <li>Open tracker overlay settings and copy the OBS URL.</li>
            <li>Create or update a Browser Source in OBS with the copied URL.</li>
            <li>Confirm tabs, ticker, and stat regions are readable in preview.</li>
            <li>Lock the source in OBS once layout is final.</li>
          </ol>
          <figure class={styles.mediaItem}>
            <Image src={IndividualTrackerStep1Screenshot} alt="Individual Tracker manager: starting a tracker" />
            <figcaption>Individual Tracker manager: starting a tracker</figcaption>
          </figure>
          <figure class={styles.mediaItem}>
            <Image src={IndividualTrackerStep2Screenshot} alt="Individual Tracker Streamer Settings" />
            <figcaption>
              Configure the streamer settings for your audience-facing overlay, then copy the OBS URL for use in a
              Browser Source. Share your viewer URL with your audience for direct access to the tracker viewer page.
            </figcaption>
          </figure>
          <figure class={styles.mediaItem}>
            <Image src={ObsStep1Screenshot} alt="OBS Browser Source settings for Guilty Spark overlay" />
            <figcaption>In OBS Studio add a Browser Source for Individual Tracker overlays.</figcaption>
          </figure>
        </div>
      </section>
    </Container>
  </section>
</Layout>
