---
import Layout from "../layouts/layout.astro";
import FAQ from "../components/faq/faq.astro";
import Container from "../components/container/container.astro";
import Heading from "../components/heading/heading.astro";
import styles from "./_styles/faq.module.css";

const faqItems = [
  {
    question: "How can I support this project?",
    answer: `Guilty Spark is currently provided to the Halo community at no cost. If you want to support ongoing development and infrastructure, sponsorships are available through <a href="https://github.com/sponsors/davidhouweling" target="_blank" rel="noopener noreferrer">GitHub Sponsors</a> or <a href="https://paypal.me/dhouweling" target="_blank" rel="noopener noreferrer">PayPal</a>.`,
  },
  {
    question: "Where can I see the full feature and capability breakdown?",
    answer: `Use <a href="/capabilities">/capabilities</a> for the latest mission map across Discord operations, live tracking, individual tracker workflows, and overlay output.`,
  },
  {
    question: "Where is the full command list for setup and account linking?",
    answer: `Use <a href="/discord-commands">/discord-commands</a> for slash command coverage, including <code>/setup</code>, <code>/connect</code>, and stats workflows.`,
  },
  {
    question: "Does Guilty Spark track ranked matches or only custom games?",
    answer: `Primary automation is optimized for <strong>custom game series</strong>, especially NeatQueue-linked workflows. You can still query a specific match using <code>/stats match &lt;match_id&gt;</code>.`,
  },
  {
    question: "Where is the full Live Tracker and Individual Tracker OBS setup guide?",
    answer: `Use the dedicated guide at <a href="/guides/obs-overlays">/guides/obs-overlays</a> for end-to-end setup flows, Browser Source recommendations, and troubleshooting notes for both overlay paths.`,
  },
  {
    question: "Can I customize which stats are displayed?",
    answer: `Yes. Server operators can tune Discord posting behavior via <code>/setup</code>, while tracker owners can tune overlay sections, ticker behavior, stat slot visibility, and style flags from tracker settings. The <a href="/capabilities">capabilities page</a> summarizes these surfaces.`,
  },
  {
    question: "Is my data stored securely?",
    answer: `Guilty Spark stores operational data required for features such as account links, server setup, and tracker state. Sensitive tokens are handled server-side with strict controls. Webhook calls are protected with HMAC validation, and Halo privacy boundaries are respected.`,
  },
  {
    question: "Why aren't my matches showing up?",
    answer: `Check Halo privacy visibility, verify <code>/connect</code> is complete, and confirm the match composition fits the workflow you are querying. Recent matches can also lag in upstream APIs, so a short delay is normal.`,
  },
  {
    question: "Does the bot require special permissions?",
    answer: `Core permissions include <strong>View Channel</strong>, <strong>Send Messages</strong>, and <strong>Use External Emojis</strong>. For webhook-driven NeatQueue workflows, <strong>Manage Webhooks</strong> is required. Missing permissions can disable parts of the automation flow.`,
  },
];
---

<Layout
  title="FAQ - Guilty Spark"
  description="Frequently asked questions about Guilty Spark, including Discord automation, Individual Tracker workflows, and OBS overlay setup."
>
  <div class={styles.faqPage}>
    <section class={styles.heroSection}>
      <Container>
        <header class={styles.heroBlock}>
          <p class={styles.eyebrow}>Archive Reference</p>
          <Heading tagName="h1" class={styles.heroTitle}>Frequently Asked Questions</Heading>
          <p class={styles.heroSubtitle}>
            Answers to common questions about operating Guilty Spark across Discord automation, Individual Tracker
            workflows, and OBS overlay setup.
          </p>
        </header>
      </Container>
    </section>
    <FAQ items={faqItems} showHeader={false} />
  </div>
</Layout>
