---
import { Image } from "astro:assets";
import Layout from "../layouts/layout.astro";
import Container from "../components/container/container.astro";
import Heading from "../components/heading/heading.astro";
import QueueStatsCommandScreenshot from "../assets/screenshot20250604-queue-stats-command.png";
import LiveTrackerScreenshot from "../assets/screenshot20250918-live-tracker.png";
import TrackerUserViewerScreenshot from "../assets/screenshot20260719-individual-tracker-user-viewer.png";
import TrackerOverlayScreenshot from "../assets/screenshot20260719-individual-tracker-overlay.png";
import styles from "./_styles/content-page.module.css";
---

<Layout
  title="Capabilities - Guilty Spark"
  description="Explore Guilty Spark capabilities across Discord automation, live series tracking, Individual Tracker workflows, and OBS-ready overlays."
>
  <section class={styles.contentPage}>
    <Container>
      <header class={styles.heroBlock}>
        <p class={styles.eyebrow}>Capability Briefing</p>
        <Heading tagName="h1" class={styles.title}>Mission Systems</Heading>
        <p class={styles.subtitle}>
          Guilty Spark now supports both community operations and streamer workflows. Use this page to review the
          current capability map before configuration or broadcast setup.
        </p>
      </header>

      <section class={styles.section} aria-label="Capability categories">
        <div class={styles.grid}>
          <article class={styles.card}>
            <h3>Discord Operations</h3>
            <p>Queue and match workflows remain first-class through slash commands and server setup controls.</p>
            <ul>
              <li>Resolve NeatQueue series stats in Discord</li>
              <li>Configure channel posting behavior and integration settings</li>
              <li>Handle account linking and command-driven retrieval</li>
            </ul>
            <figure class={styles.mediaItem}>
              <Image
                src={QueueStatsCommandScreenshot}
                alt="NeatQueue series stats resolved in Discord via slash command"
              />
              <figcaption>Resolve NeatQueue series stats directly in Discord with a slash command.</figcaption>
            </figure>
          </article>

          <article class={styles.card}>
            <h3>Live Series Tracking</h3>
            <p>Track active queue states with controls for refresh cadence and operational continuity.</p>
            <ul>
              <li>Automatic start/stop from queue lifecycle events</li>
              <li>Substitution-aware updates during active series</li>
              <li>Optional score projection into channel names</li>
            </ul>
            <figure class={styles.mediaItem}>
              <Image src={LiveTrackerScreenshot} alt="Live Tracker showing active series and match details" />
              <figcaption>Live Tracker showing active series and match details</figcaption>
            </figure>
          </article>

          <article class={styles.card}>
            <h3>Individual Tracker</h3>
            <p>Manage player-centered trackers independent of a single queue timeline.</p>
            <ul>
              <li>Create and manage personal tracking workflows</li>
              <li>Tune streamer settings per context</li>
              <li>Share public viewer pages for audience follow-along</li>
            </ul>
            <figure class={styles.mediaItem}>
              <Image
                src={TrackerUserViewerScreenshot}
                alt="Individual Tracker user-level viewer showing lineup and score details"
              />
              <figcaption>Individual Tracker user-level viewer showing lineup and score details</figcaption>
            </figure>
          </article>

          <article class={styles.card}>
            <h3>OBS Overlay Output</h3>
            <p>Generate Browser Source URLs from both live tracker and individual tracker flows.</p>
            <ul>
              <li>Overlay URLs generated from in-app settings</li>
              <li>Context-aware display for in-series and matchmaking states</li>
              <li>Compatible with standard OBS browser source workflows</li>
            </ul>
            <figure class={styles.mediaItem}>
              <Image
                src={TrackerOverlayScreenshot}
                alt="OBS overlay output showing Guilty Spark overlay as a browser source"
              />
              <figcaption>OBS overlay output showing Guilty Spark overlay as a browser source</figcaption>
            </figure>
          </article>
        </div>
      </section>
    </Container>
  </section>
</Layout>
