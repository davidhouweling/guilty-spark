---
export const prerender = false;

import Layout from "../../layouts/layout.astro";
import { API_HOST } from "../../constants";
import { IndividualTrackerViewerApp } from "../../apps/individual-tracker-viewer/create";

const { trackerId } = Astro.params;
---

<Layout title="Tracker - Guilty Spark" description="View an individual live tracker">
  <IndividualTrackerViewerApp client:only="react" apiHost={API_HOST} trackerId={trackerId ?? ""} />
</Layout>
