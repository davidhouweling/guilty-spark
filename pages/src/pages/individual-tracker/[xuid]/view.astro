---
export const prerender = false;

import Layout from "../../../layouts/layout.astro";
import { API_HOST } from "../../../constants";
import { IndividualTrackerPublicApp } from "../../../apps/individual-tracker-public/create";

const { xuid } = Astro.params;
---

<Layout title="Tracker - Guilty Spark" description="View an individual live tracker">
