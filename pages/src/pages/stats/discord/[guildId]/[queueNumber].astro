---
export const prerender = false;

import { API_HOST } from "../../../../constants";
import Layout from "../../../../layouts/layout.astro";
import { DiscordSeriesStatsApp } from "../../../../apps/discord-series-stats/create";
import LoadingState from "../../../../components/loading-state/loading-state.astro";
import ErrorState from "../../../../components/error-state/error-state.astro";
import { installDiscordSeriesStatsService } from "../../../../services/stats/install";

const { guildId = "", queueNumber = "" } = Astro.params;

const isSnowflake = /^\d+$/.test(guildId);
const isStrictPositiveInteger = /^[1-9]\d*$/.test(queueNumber);
const parsedQueueNumber = Number(queueNumber);
const isSafeQueueNumber = Number.isSafeInteger(parsedQueueNumber) && parsedQueueNumber > 0;
const hasInvalidParams = !isSnowflake || !isStrictPositiveInteger || !isSafeQueueNumber;
let lookupStatus = hasInvalidParams ? 404 : 500;
let retryAfterSeconds = 2;

function getPendingRetryAfterSeconds(responseRetryAfterSeconds: number | null): number {
  if (responseRetryAfterSeconds == null) {
    return 2;
  }

  return Math.ceil(responseRetryAfterSeconds);
}

if (hasInvalidParams) {
  Astro.response.status = 404;
} else {
  try {
    const statsService = await installDiscordSeriesStatsService(String(API_HOST));
    const response = await statsService.getLookup(guildId, queueNumber);
    lookupStatus = response.status;
    Astro.response.status = lookupStatus;

    if (lookupStatus === 503) {
      retryAfterSeconds = getPendingRetryAfterSeconds(response.retryAfterSeconds);
      Astro.response.headers.set("Cache-Control", "no-store");
      Astro.response.headers.set("Retry-After", retryAfterSeconds.toString());
    } else if (lookupStatus >= 500) {
      Astro.response.headers.set("Cache-Control", "no-store");
    }
  } catch {
    Astro.response.status = 500;
    lookupStatus = 500;
    Astro.response.headers.set("Cache-Control", "no-store");
  }
}
---

<Layout title={`Queue #${queueNumber} Stats - Guilty Spark`} description="Series stats for a completed queue">
  {
    hasInvalidParams || lookupStatus === 404 ? (
      <ErrorState title="Queue not found" message="No matching queue was found for this guild." />
    ) : lookupStatus === 200 ? (
      <DiscordSeriesStatsApp client:only="react" apiHost={API_HOST} guildId={guildId} queueNumber={queueNumber} />
    ) : lookupStatus === 503 ? (
      <LoadingState text={`Stats are still indexing. Retry in ${retryAfterSeconds.toString()}s.`} />
    ) : lookupStatus === 403 ? (
      <ErrorState title="Access forbidden" message="Missing Discord permissions or message content access" />
    ) : (
      <ErrorState title="Unable to load stats" message="Failed to validate queue stats" />
    )
  }
</Layout>
